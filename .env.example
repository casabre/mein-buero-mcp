# Get ownershipId: click "Erweiterung testen" in MeinBüro Marketplace → callback ?iid=<ownershipId>
MEINBUERO_OWNERSHIP_ID=your_ownership_id_here

# API base URL (production default)
MEINBUERO_API_BASE_URL=https://api.meinbuero.de/openapi

# Transport: stdio | http | sse  (default: stdio)
TRANSPORT=stdio
PORT=3000

# Optional: require x-api-key header on MCP server (leave unset for Claude Desktop / local use)
MEINBUERO_MCP_API_KEY=
